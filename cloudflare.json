{
  "build": {
    "command": "cp cloudflare-package.json package.json && node cloudflare-build.cjs",
    "environment": {
      "NODE_VERSION": "20",
      "BUN_INSTALL": "false",
      "USE_BUN": "false",
      "PACKAGE_MANAGER": "npm",
      "NPM_FLAGS": "--no-package-lock --legacy-peer-deps"
    }
  }
}
